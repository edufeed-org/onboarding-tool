# Enable/disable Keycloak synchronization
# Set to "true" to enable, any other value to disable
NEXT_PUBLIC_ENABLE_KEYCLOAK_SYNC=true

# Public Keycloak configuration (available in browser)
# Only used if NEXT_PUBLIC_ENABLE_KEYCLOAK_SYNC is set to "true"
# Note: Removed '/auth' from the URL path as newer Keycloak versions don't use it
NEXT_PUBLIC_KEYCLOAK_INSTANCE_URL=https://keycloak.example.com
NEXT_PUBLIC_KEYCLOAK_REALM=your-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=your-client-id

# Server-side Keycloak configuration (not exposed to browser)
# These variables are used by the API routes for secure communication with Keycloak
# Note: Removed '/auth' from the URL path as newer Keycloak versions don't use it
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=your-client-secret

# Security configuration
# Generate a 64-character hex key for AES-256 encryption (32 bytes)
# Example: openssl rand -hex 32
ENCRYPTION_KEY=your-64-character-hex-encryption-key