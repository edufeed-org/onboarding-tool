# OIDC / SSO Configuration
# Configure these variables to enable Single Sign-On (SSO) login via OpenID Connect

# Your OAuth 2.0 client ID from your Identity Provider
VITE_OIDC_CLIENT_ID=

# Your OAuth 2.0 client secret (required for confidential clients)
VITE_OIDC_CLIENT_SECRET=

# Authorization endpoint URL (e.g., https://your-idp.example.com/authorize)
VITE_OIDC_AUTHORIZATION_ENDPOINT=

# Token endpoint URL (e.g., https://your-idp.example.com/oauth/token)
# Note: This endpoint must support CORS for browser-based token exchange
VITE_OIDC_TOKEN_ENDPOINT=

# Issuer identifier (e.g., https://your-idp.example.com)
VITE_OIDC_ISSUER=

# OAuth scopes to request (optional, defaults to 'openid profile email nostr')
# The 'nostr' scope should return 'npub' and optionally 'nsec' in ID token claims
VITE_OIDC_SCOPE=openid profile email nostr

# Starter Packs Configuration (optional)
# JSON array of starter pack naddr identifiers to display
# Example: ["naddr1...", "naddr1..."]
VITE_STARTER_PACKS=

# Interest Sets Configuration (optional)
# JSON array of interest set configurations
# Example: [{"naddr": "naddr1...", "title": "Tech"}, {"naddr": "naddr1...", "title": "Art"}]
VITE_INTEREST_SETS=
